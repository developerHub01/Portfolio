<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN" "http://www.w3.org/TR/html4/loose.dtd">
<html>

<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <title>Portfolio, client email.</title>
</head>

<body bgcolor="#eef2f6" style="margin:0;padding:0;">
  <table width="100%" border="0" cellspacing="0" cellpadding="0" bgcolor="#eef2f6">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table width="640" border="0" cellspacing="0" cellpadding="0" bgcolor="#ffffff"
          style="border:1px solid #d8e0e8;">
          <tr>
            <td bgcolor="#0f172a" style="padding:20px 24px;font-family:Arial,Helvetica,sans-serif;color:#ffffff;">
              <font size="4"><strong>New email from portfolio</strong></font>
            </td>
          </tr>
          <tr>
            <td style="padding:20px 24px;font-family:Arial,Helvetica,sans-serif;color:#111827;">
              <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <tr>
                  <td width="150" valign="top" style="padding:8px 0;color:#475569;"><strong>Name</strong></td>
                  <td valign="top" style="padding:8px 0;">
                    <%= name %>
                  </td>
                </tr>
                <tr>
                  <td width="150" valign="top" style="padding:8px 0;color:#475569;"><strong>Email</strong></td>
                  <td valign="top" style="padding:8px 0;">
                    <%= email %>
                  </td>
                </tr>
                <tr>
                  <td width="150" valign="top" style="padding:8px 0;color:#475569;"><strong>Sent (UTC)</strong></td>
                  <td valign="top" style="padding:8px 0;">
                    <%= sentAt %>
                  </td>
                </tr>
                <tr>
                  <td width="150" valign="top" style="padding:8px 0;color:#475569;"><strong>Message</strong></td>
                  <td valign="top" style="padding:8px 0;line-height:1.6;white-space:pre-wrap;">
                    <%= message %>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td bgcolor="#f8fafc"
              style="padding:12px 24px;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#64748b;border-top:1px solid #e2e8f0;">
              Sent from portfolio contact form.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>

</html>